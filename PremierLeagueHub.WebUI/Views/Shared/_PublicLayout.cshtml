<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - PremierLeagueHub</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/public-site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>

    <header class="public-navbar">
        <div class="container d-flex justify-content-between align-items-center">
            <a href="/" class="public-brand">
                Premier<span>League</span>Hub
            </a>

            <nav class="d-flex align-items-center">
                <a href="/" class="public-nav-link">Home</a>
                <a href="/#teams" class="public-nav-link">Teams</a>
                <a href="/Admin/Dashboard/Index" class="btn btn-primary public-admin-btn ms-3">
                    Admin Panel
                </a>
            </nav>
        </div>
    </header>

    <main class="public-main">
        @RenderBody()
    </main>

    <footer class="public-footer">
        <div class="container d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <strong>PremierLeagueHub</strong>
                <div>Modern football management platform built with ASP.NET Core MVC and Web API.</div>
            </div>

            <div>
                <a href="/Admin/Dashboard/Index" class="btn btn-outline-light rounded-pill px-4">
                    Admin Panel
                </a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>