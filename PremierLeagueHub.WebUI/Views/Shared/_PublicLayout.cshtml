@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - PremierLeagueHub</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/public-site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>

    <header class="public-navbar">
        <div class="container public-navbar-inner d-flex justify-content-between align-items-center">
            <a href="/" class="public-brand">
                <div class="brand-ball">⚽</div>
                Premier<span>League</span>Hub
            </a>

            <nav class="d-flex align-items-center">
                <a href="/" class="public-nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")">
                    Home
                </a>

                <a href="/#teams" class="public-nav-link">
                    Teams
                </a>

                <a href="#" class="public-nav-link">
                    Fixtures
                </a>

                <a href="#" class="public-nav-link">
                    Standings
                </a>

                <a href="/Admin/Dashboard/Index" class="public-admin-btn ms-3">
                    Admin
                </a>
            </nav>
        </div>
    </header>

    <main class="public-main">
        @RenderBody()
    </main>

    <footer class="public-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-5">
                    <strong>Premier<span>League</span>Hub</strong>
                    <p class="mt-2 mb-0">
                        Modern football management platform built with ASP.NET Core MVC, Web API, DTOs, services and admin management.
                    </p>
                </div>

                <div class="col-lg-3">
                    <strong>Platform</strong>
                    <div class="mt-2">
                        <a href="/" class="d-block text-muted mb-1">Home</a>
                        <a href="/#teams" class="d-block text-muted mb-1">Teams</a>
                        <a href="/Admin/Dashboard/Index" class="d-block text-muted mb-1">Admin Panel</a>
                    </div>
                </div>

                <div class="col-lg-4 text-lg-end">
                    <strong>Project Status</strong>
                    <p class="mt-2 mb-0">
                        Teams module, admin CRUD, public showcase and detail pages are active.
                    </p>
                </div>
            </div>

            <div class="border-top mt-4 pt-3 d-flex justify-content-between flex-wrap gap-2" style="border-color: var(--pl-border) !important;">
                <span class="text-muted">© 2026 PremierLeagueHub</span>
                <span class="text-muted">Demo football data is used for portfolio purposes.</span>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>