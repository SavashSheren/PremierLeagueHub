@model GetTeamByIdDto

@{
    ViewData["Title"] = Model.TeamName;
}

<style>
    body {
        background: #f4f7fb;
        color: #0f172a;
    }

    .detail-hero {
        margin-top: 28px;
        border-radius: 34px;
        padding: 48px;
        color: white;
        background: linear-gradient(135deg, @Model.PrimaryColor, #0f172a 70%);
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(15, 23, 42, 0.18);
    }

        .detail-hero::after {
            content: "";
            position: absolute;
            width: 320px;
            height: 320px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.08);
            right: -90px;
            top: -90px;
        }

    .detail-logo {
        width: 120px;
        height: 120px;
        object-fit: contain;
        background: white;
        border-radius: 28px;
        padding: 18px;
        border: 1px solid rgba(255,255,255,0.25);
        position: relative;
        z-index: 2;
    }

    .detail-title {
        font-size: 52px;
        font-weight: 900;
        letter-spacing: -1.2px;
        margin-bottom: 6px;
        position: relative;
        z-index: 2;
    }

    .detail-short {
        color: #dbeafe;
        font-size: 18px;
        font-weight: 700;
        position: relative;
        z-index: 2;
    }

    .detail-card {
        background: white;
        border-radius: 28px;
        padding: 30px;
        box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
        height: 100%;
    }

    .info-label {
        color: #64748b;
        font-size: 13px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 4px;
    }

    .info-value {
        font-size: 17px;
        font-weight: 800;
        color: #0f172a;
    }

    .color-box {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        display: inline-block;
        border: 1px solid #e5e7eb;
        margin-right: 10px;
    }

    .description-box {
        line-height: 1.8;
        color: #334155;
        font-size: 16px;
    }

    .back-btn {
        border-radius: 999px;
        padding: 12px 22px;
        font-weight: 800;
    }

    .status-pill {
        border-radius: 999px;
        padding: 8px 14px;
        font-weight: 800;
    }
</style>

<div class="container">
    <section class="detail-hero">
        <div class="d-flex align-items-center gap-4 flex-wrap">
            <img src="@Model.LogoUrl" class="detail-logo" alt="@Model.TeamName logo" />

            <div>
                <h1 class="detail-title">@Model.TeamName</h1>
                <div class="detail-short">@Model.ShortName • @Model.City</div>
            </div>
        </div>
    </section>

    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
        <a href="/" class="btn btn-light back-btn">
            Back to Teams
        </a>

        @if (Model.IsActive)
        {
            <span class="badge bg-success status-pill">Active Team</span>
        }
        else
        {
            <span class="badge bg-secondary status-pill">Passive Team</span>
        }
    </div>

    <div class="row g-4 mb-5">
        <div class="col-xl-8">
            <div class="detail-card">
                <h3 class="fw-bold mb-3">Club Overview</h3>
                <p class="description-box mb-0">
                    @Model.Description
                </p>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="detail-card">
                <h3 class="fw-bold mb-4">Club Colors</h3>

                <div class="d-flex align-items-center mb-3">
                    <span class="color-box" style="background:@Model.PrimaryColor"></span>
                    <div>
                        <div class="info-label">Primary Color</div>
                        <div class="info-value">@Model.PrimaryColor</div>
                    </div>
                </div>

                <div class="d-flex align-items-center">
                    <span class="color-box" style="background:@Model.SecondaryColor"></span>
                    <div>
                        <div class="info-label">Secondary Color</div>
                        <div class="info-value">@Model.SecondaryColor</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="detail-card">
                <div class="info-label">City</div>
                <div class="info-value">@Model.City</div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="detail-card">
                <div class="info-label">Stadium</div>
                <div class="info-value">@Model.StadiumName</div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="detail-card">
                <div class="info-label">Founded Year</div>
                <div class="info-value">@Model.FoundedYear</div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="detail-card">
                <div class="info-label">Manager</div>
                <div class="info-value">@Model.ManagerName</div>
            </div>
        </div>

        <div class="col-12">
            <div class="detail-card d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <div class="info-label">Official Website</div>
                    <div class="info-value">@Model.WebsiteUrl</div>
                </div>

                <a href="@Model.WebsiteUrl" target="_blank" class="btn btn-primary rounded-pill px-4">
                    Visit Website
                </a>
            </div>
        </div>
    </div>
</div>