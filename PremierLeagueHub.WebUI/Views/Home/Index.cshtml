@model PublicTeamListViewModel

@{
    ViewData["Title"] = "Premier League Hub";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<div class="container">
    <section class="public-hero">
        <span class="hero-badge">Premier League Management Platform</span>

        <h1>Explore Premier League Clubs in One Modern Hub</h1>

        <p>
            Discover clubs, stadiums, managers and team identities through a clean ASP.NET Core MVC + Web API architecture.
        </p>

        <div class="hero-actions">
            <a href="#teams" class="btn btn-light">Explore Teams</a>
            <a href="/Admin/Dashboard/Index" class="btn btn-outline-light">Admin Panel</a>
        </div>
    </section>

    <section class="filter-panel">
        <form method="get" asp-controller="Home" asp-action="Index">
            <div class="row g-3 align-items-end">
                <div class="col-xl-5 col-lg-4">
                    <label>Search</label>
                    <input name="searchTerm"
                           value="@Model.SearchTerm"
                           class="form-control"
                           placeholder="Search by team, city, stadium or manager..." />
                </div>

                <div class="col-xl-3 col-lg-3">
                    <label>Status</label>
                    <select name="statusFilter" class="form-select">
                        <option value="all" selected="@(Model.StatusFilter == "all")">All Teams</option>
                        <option value="active" selected="@(Model.StatusFilter == "active")">Active Teams</option>
                        <option value="passive" selected="@(Model.StatusFilter == "passive")">Passive Teams</option>
                    </select>
                </div>

                <div class="col-xl-3 col-lg-3">
                    <label>City</label>
                    <select name="cityFilter" class="form-select">
                        <option value="all" selected="@(Model.CityFilter == "all")">All Cities</option>

                        @foreach (var city in Model.Cities)
                        {
                            <option value="@city" selected="@(Model.CityFilter == city)">
                                @city
                            </option>
                        }
                    </select>
                </div>

                <div class="col-xl-1 col-lg-2 d-grid">
                    <button type="submit" class="btn btn-primary rounded-pill py-3">
                        Filter
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.SearchTerm) || Model.StatusFilter != "all" || Model.CityFilter != "all")
            {
                <div class="mt-3">
                    <a href="/" class="btn btn-light rounded-pill px-4">
                        Clear Filters
                    </a>
                </div>
            }
        </form>
    </section>

    <section id="teams" class="mb-5">
        <div class="section-title">
            <div>
                <h2>Premier League Teams</h2>
                <p>
                    <span class="result-pill">@Model.FilteredTeamsCount result(s)</span>
                    <span class="ms-2 text-muted">from @Model.TotalTeams total club record(s).</span>
                </p>
            </div>
        </div>

        @if (ViewBag.ApiError != null)
        {
            <div class="alert alert-danger rounded-4">
                @ViewBag.ApiError
            </div>
        }

        @if (!Model.Teams.Any())
        {
            <div class="empty-state">
                <h4>No teams found.</h4>
                <p class="text-muted mb-0">Try changing your search or filter options.</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var team in Model.Teams)
                {
                    <div class="col-xl-4 col-lg-6">
                        <div class="public-team-card">
                            <div class="public-club-strip" style="background:@team.PrimaryColor"></div>

                            <div class="public-team-body">
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@team.LogoUrl" class="public-team-logo" alt="@team.TeamName logo" />

                                    <div>
                                        <div class="club-name">@team.TeamName</div>
                                        <div class="club-short">@team.ShortName</div>
                                    </div>
                                </div>

                                <div class="club-meta">
                                    <div class="club-meta-item">
                                        <span>City</span>
                                        <strong>@team.City</strong>
                                    </div>

                                    <div class="club-meta-item">
                                        <span>Stadium</span>
                                        <strong>@team.StadiumName</strong>
                                    </div>

                                    <div class="club-meta-item">
                                        <span>Manager</span>
                                        <strong>@team.ManagerName</strong>
                                    </div>

                                    <div class="club-meta-item">
                                        <span>Club Colors</span>
                                        <span class="color-dot" style="background:@team.PrimaryColor"></span>
                                        <span class="color-dot" style="background:@team.SecondaryColor"></span>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between align-items-center mt-4">
                                    @if (team.IsActive)
                                    {
                                        <span class="badge bg-success rounded-pill px-3 py-2">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3 py-2">Passive</span>
                                    }

                                    <a href="/Home/TeamDetail/@team.TeamId" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        View Details
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>
    @if (ViewBag.FixtureApiError != null)
    {
        <div class="alert alert-danger rounded-4">
            @ViewBag.FixtureApiError
        </div>
    }

    @if (Model.FeaturedFixture != null)
    {
        var featured = Model.FeaturedFixture;

        <section class="home-featured-grid">
            <div class="home-featured-match-card">
                <div class="featured-card-header">
                    <div>
                        <span>Featured Match</span>
                        <h2>@featured.HomeTeamName vs @featured.AwayTeamName</h2>
                    </div>

                    @if (featured.IsTopMatch)
                    {
                        <div class="featured-top-badge">Top Match</div>
                    }
                </div>

                <div class="featured-scoreboard">
                    <div class="featured-team">
                        <img src="@featured.HomeTeamLogoUrl" alt="@featured.HomeTeamName logo" />
                        <strong>@featured.HomeTeamShortName</strong>
                        <span>@featured.HomeTeamName</span>
                    </div>

                    <div class="featured-center">
                        @if (featured.HasResult)
                        {
                            <div class="featured-score">
                                @featured.HomeScore - @featured.AwayScore
                            </div>
                        }
                        else
                        {
                            <div class="featured-vs">VS</div>
                        }

                        <span>@featured.MatchDate.ToString("dd MMM yyyy HH:mm")</span>
                    </div>

                    <div class="featured-team">
                        <img src="@featured.AwayTeamLogoUrl" alt="@featured.AwayTeamName logo" />
                        <strong>@featured.AwayTeamShortName</strong>
                        <span>@featured.AwayTeamName</span>
                    </div>
                </div>

                <div class="featured-footer">
                    <div>
                        <span>Stadium</span>
                        <strong>@featured.StadiumName</strong>
                    </div>

                    <a href="/Fixtures/Detail/@featured.FixtureId" class="btn btn-primary rounded-pill px-4">
                        Match Details
                    </a>
                </div>
            </div>

            <div class="home-result-card">
                <div class="featured-card-header compact">
                    <div>
                        <span>Latest Results</span>
                        <h2>@Model.FinishedMatchesCount Finished</h2>
                    </div>

                    <a href="/Fixtures/Index" class="home-mini-link">
                        View All
                    </a>
                </div>

                @if (!Model.LatestResults.Any())
                {
                    <div class="home-empty-mini">
                        No finished matches yet.
                    </div>
                }
                else
                {
                    <div class="home-result-list">
                        @foreach (var result in Model.LatestResults)
                        {
                            <a href="/Fixtures/Detail/@result.FixtureId" class="home-result-item">
                                <span>@result.HomeTeamShortName</span>

                                <strong>
                                    @if (result.HasResult)
                                    {
                                        @($"{result.HomeScore} - {result.AwayScore}")
                                    }
                                    else
                                    {
                                        @("VS")
                                    }
                                </strong>

                                <span>@result.AwayTeamShortName</span>
                            </a>
                        }
                    </div>
                }
            </div>
        </section>
    }
</div>