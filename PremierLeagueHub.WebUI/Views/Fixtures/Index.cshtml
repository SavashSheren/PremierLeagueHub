@model PublicFixtureListViewModel

@{
    ViewData["Title"] = "Premier League Fixtures";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";

    var groupedFixtures = Model.Fixtures
        .GroupBy(x => x.MatchDate.Date)
        .OrderBy(x => x.Key)
        .ToList();
}

<section class="fixtures-header">
    <div class="container">
        <div class="row align-items-end">
            <div class="col-lg-7">
                <div class="league-badge">Premier League</div>
                <h1>Week <span>@Model.WeekNumber</span> Fixtures</h1>
                <p>@Model.Season season · Scheduled Premier League matches</p>
            </div>

            <div class="col-lg-5 mt-3 mt-lg-0">
                <div class="fixture-summary-grid">
                    <div class="fixture-summary-card">
                        <strong>@Model.TotalFixtures</strong>
                        <span>Total Matches</span>
                    </div>

                    <div class="fixture-summary-card">
                        <strong>@Model.TopMatchCount</strong>
                        <span>Top Matches</span>
                    </div>

                    <div class="fixture-summary-card">
                        <strong>@groupedFixtures.Count</strong>
                        <span>Match Days</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="container fixtures-content">

    @if (ViewBag.ApiError != null)
    {
        <div class="alert alert-danger rounded-4">
            @ViewBag.ApiError
        </div>
    }

    @if (!Model.Fixtures.Any())
    {
        <div class="empty-state">
            <h4>No fixtures found.</h4>
            <p class="text-muted mb-0">Run the Week 34 fixture seed endpoint from Swagger first.</p>
        </div>
    }
    else
    {
        @foreach (var group in groupedFixtures)
        {
            <section class="fixture-day-group">
                <div class="fixture-day-header">
                    <div>
                        <h3>@group.Key.ToString("dddd")</h3>
                        <span>@group.Key.ToString("dd MMM yyyy")</span>
                    </div>

                    <div class="fixture-day-line"></div>

                    <span class="fixture-day-count">
                        @group.Count() Match(es)
                    </span>
                </div>

                @foreach (var fixture in group.OrderBy(x => x.MatchDate))
                {
                    <div class="fixture-card @(fixture.IsTopMatch ? "top-match" : "")">
                        @if (fixture.IsTopMatch)
                        {
                            <div class="fixture-top-strip"></div>
                        }

                        <div class="fixture-inner">
                            <div class="fixture-time-col">
                                <div class="fixture-time">@fixture.MatchDate.ToString("HH:mm")</div>

                                @if (fixture.IsTopMatch)
                                {
                                    <div class="fixture-top-badge">Top</div>
                                }
                                else
                                {
                                    <div class="fixture-status">@fixture.Status</div>
                                }
                            </div>

                            <div class="fixture-divider"></div>

                            <div class="fixture-teams">
                                <div class="fixture-team home">
                                    <span>@fixture.HomeTeamName</span>
                                    <img src="@fixture.HomeTeamLogoUrl" alt="@fixture.HomeTeamName logo" />
                                </div>

                                <div class="fixture-vs">
                                    <strong>VS</strong>
                                    <span>Week @fixture.WeekNumber</span>
                                </div>

                                <div class="fixture-team away">
                                    <img src="@fixture.AwayTeamLogoUrl" alt="@fixture.AwayTeamName logo" />
                                    <span>@fixture.AwayTeamName</span>
                                </div>
                            </div>

                            <div class="fixture-meta">
                                <div>@fixture.StadiumName</div>
                                <a href="#" class="fixture-detail-btn disabled">
                                    Details Soon
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </section>
        }
    }
</div>