@model PublicFixtureDetailViewModel

@{
    var fixture = Model.Fixture;

    ViewData["Title"] = $"{fixture.HomeTeamName} vs {fixture.AwayTeamName}";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

@functions {
    private string GetEventIcon(string eventType)
    {
        return eventType switch
        {
            "Goal" => "⚽",
            "Penalty" => "🎯",
            "YellowCard" => "🟨",
            "RedCard" => "🟥",
            "Substitution" => "🔁",
            "VAR" => "📺",
            _ => "•"
        };
    }

    private string GetEventClass(string eventType)
    {
        return eventType switch
        {
            "Goal" => "goal-event",
            "Penalty" => "penalty-event",
            "YellowCard" => "yellow-event",
            "RedCard" => "red-event",
            "Substitution" => "sub-event",
            "VAR" => "var-event",
            _ => "default-event"
        };
    }
}

<section class="fixture-detail-hero">
    <div class="container">
        <div class="fixture-detail-badges">
            <span>Premier League</span>
            <span>Week @fixture.WeekNumber</span>

            @if (fixture.IsTopMatch)
            {
                <span class="gold">Top Match</span>
            }
            else
            {
                <span>@fixture.Status</span>
            }
        </div>

        <div class="fixture-detail-scoreboard">
            <div class="fixture-detail-team home">
                <img src="@fixture.HomeTeamLogoUrl" alt="@fixture.HomeTeamName logo" />
                <h2>@fixture.HomeTeamName</h2>
                <p>@fixture.HomeTeamShortName</p>
            </div>

            <div class="fixture-detail-center">
                <div class="fixture-detail-date">
                    @fixture.MatchDate.ToString("dd MMM yyyy")
                </div>

                <div class="fixture-detail-vs">
                    @if (fixture.HasResult)
                    {
                        <span class="fixture-detail-score">@fixture.HomeScore - @fixture.AwayScore</span>
                    }
                    else
                    {
                        <span>VS</span>
                    }
                </div>

                <div class="fixture-detail-time">
                    @fixture.MatchDate.ToString("HH:mm")
                </div>
            </div>

            <div class="fixture-detail-team away">
                <img src="@fixture.AwayTeamLogoUrl" alt="@fixture.AwayTeamName logo" />
                <h2>@fixture.AwayTeamName</h2>
                <p>@fixture.AwayTeamShortName</p>
            </div>
        </div>

        <div class="fixture-detail-meta-strip">
            <div>
                <span>Season</span>
                <strong>@fixture.Season</strong>
            </div>

            <div>
                <span>Stadium</span>
                <strong>@fixture.StadiumName</strong>
            </div>

            <div>
                <span>Status</span>
                <strong>@fixture.Status</strong>
            </div>
        </div>
    </div>
</section>

<div class="container fixture-detail-content">

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger rounded-4">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <a href="/Fixtures/Index" class="btn btn-light back-btn">
            Back to Fixtures
        </a>

        <a href="/Standings/Index" class="btn btn-outline-primary rounded-pill px-4">
            View Standings
        </a>
    </div>

    <div class="row g-4">
        <div class="col-xl-8">
            <div class="fixture-preview-card">
                <div class="fixture-card-title">
                    Match Timeline
                </div>

                @if (!Model.HasEvents)
                {
                    <div class="timeline-empty-state">
                        <h3>No match events yet.</h3>
                        <p>
                            Add goals, cards, substitutions or VAR events from Swagger for now.
                            Admin match event management will come next.
                        </p>
                    </div>
                }
                else
                {
                    <div class="match-timeline">
                        @foreach (var matchEvent in Model.MatchEvents)
                        {
                            var isHomeEvent = matchEvent.TeamId == fixture.HomeTeamId;

                            <div class="match-event-row @(isHomeEvent ? "home-event" : "away-event")">
                                <div class="event-minute">
                                    @matchEvent.Minute'
                                </div>

                                <div class="event-card @GetEventClass(matchEvent.EventType)">
                                    <div class="event-icon">
                                        @GetEventIcon(matchEvent.EventType)
                                    </div>

                                    <div class="event-content">
                                        <div class="event-main-line">
                                            <strong>@matchEvent.EventType</strong>
                                            <span>@matchEvent.TeamShortName</span>
                                        </div>

                                        <h4>@matchEvent.PlayerName</h4>

                                        @if (!string.IsNullOrWhiteSpace(matchEvent.AssistPlayerName))
                                        {
                                            <p>Assist: @matchEvent.AssistPlayerName</p>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(matchEvent.RelatedPlayerName))
                                        {
                                            <p>Related player: @matchEvent.RelatedPlayerName</p>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(matchEvent.Description))
                                        {
                                            <p>@matchEvent.Description</p>
                                        }
                                    </div>

                                    <img src="@matchEvent.TeamLogoUrl" alt="@matchEvent.TeamName logo" />
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="col-xl-4">
            <div class="fixture-preview-card">
                <div class="fixture-card-title">
                    Match Status
                </div>

                <div class="fixture-status-big">
                    @fixture.Status
                </div>

                <p class="mb-4">
                    This fixture detail page is now connected to match events and ready for admin timeline management.
                </p>

                <div class="fixture-preview-grid single-column">
                    <div>
                        <span>Home Team</span>
                        <strong>@fixture.HomeTeamName</strong>
                    </div>

                    <div>
                        <span>Away Team</span>
                        <strong>@fixture.AwayTeamName</strong>
                    </div>

                    <div>
                        <span>Events</span>
                        <strong>@Model.MatchEvents.Count event(s)</strong>
                    </div>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <a href="/Home/TeamDetail/@fixture.HomeTeamId" class="btn btn-primary rounded-pill">
                        View @fixture.HomeTeamShortName
                    </a>

                    <a href="/Home/TeamDetail/@fixture.AwayTeamId" class="btn btn-light rounded-pill">
                        View @fixture.AwayTeamShortName
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>