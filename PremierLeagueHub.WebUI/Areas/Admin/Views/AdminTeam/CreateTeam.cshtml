@model CreateTeamDto

@{
    ViewData["Title"] = "Create Team";
    ViewData["Description"] = "Add a new Premier League club with stadium, manager, logo and club colors.";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="form-card">
    <form asp-action="CreateTeam" asp-controller="AdminTeam" asp-area="Admin" method="post">

        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4"></div>

        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="TeamName" class="form-label">Team Name</label>
                <input asp-for="TeamName" class="form-control" placeholder="Arsenal" />
                <span asp-validation-for="TeamName" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="ShortName" class="form-label">Short Name</label>
                <input asp-for="ShortName" class="form-control" placeholder="ARS" />
                <span asp-validation-for="ShortName" class="text-danger"></span>
            </div>

            <div class="col-md-12">
                <label asp-for="LogoUrl" class="form-label">Logo URL</label>
                <input asp-for="LogoUrl" class="form-control" placeholder="https://..." />
                <span asp-validation-for="LogoUrl" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="City" class="form-label">City</label>
                <input asp-for="City" class="form-control" placeholder="London" />
                <span asp-validation-for="City" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="StadiumName" class="form-label">Stadium Name</label>
                <input asp-for="StadiumName" class="form-control" placeholder="Emirates Stadium" />
                <span asp-validation-for="StadiumName" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="FoundedYear" class="form-label">Founded Year</label>
                <input asp-for="FoundedYear" class="form-control" placeholder="1886" />
                <span asp-validation-for="FoundedYear" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="ManagerName" class="form-label">Manager Name</label>
                <input asp-for="ManagerName" class="form-control" placeholder="Mikel Arteta" />
                <span asp-validation-for="ManagerName" class="text-danger"></span>
            </div>

            <div class="col-md-12">
                <label asp-for="WebsiteUrl" class="form-label">Website URL</label>
                <input asp-for="WebsiteUrl" class="form-control" placeholder="https://www.arsenal.com" />
                <span asp-validation-for="WebsiteUrl" class="text-danger"></span>
            </div>

            <div class="col-md-12">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="5" placeholder="Write a short club description..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="PrimaryColor" class="form-label">Primary Color</label>
                <input asp-for="PrimaryColor" class="form-control" placeholder="#EF0107" />
                <span asp-validation-for="PrimaryColor" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="SecondaryColor" class="form-label">Secondary Color</label>
                <input asp-for="SecondaryColor" class="form-control" placeholder="#FFFFFF" />
                <span asp-validation-for="SecondaryColor" class="text-danger"></span>
            </div>

            <div class="col-md-12">
                <div class="form-check form-switch">
                    <input asp-for="IsActive" class="form-check-input" checked />
                    <label asp-for="IsActive" class="form-check-label">Active Team</label>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between mt-5">
            <a href="/Admin/AdminTeam/Index" class="btn btn-light rounded-pill px-4">
                Back to List
            </a>

            <button type="submit" class="btn btn-primary rounded-pill px-5">
                Create Team
            </button>
        </div>

    </form>
</div>