@model List<ResultTeamDto>

@{
    ViewData["Title"] = "Team Management";
    ViewData["Description"] = "Manage Premier League clubs, stadiums, colors and team details.";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Teams</h4>
        <span class="text-muted">@Model.Count team(s) found</span>
    </div>

    <a href="/Admin/AdminTeam/CreateTeam" class="btn btn-primary rounded-pill px-4">
        Add New Team
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-warning rounded-4">
        No teams found. Please add your first team.
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var team in Model)
        {
            <div class="col-xl-4 col-lg-6">
                <div class="card team-card">
                    <div class="club-strip" style="background:@team.PrimaryColor"></div>

                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <img src="@team.LogoUrl" class="team-logo" alt="@team.TeamName logo" />

                            <div>
                                <h5 class="mb-1">@team.TeamName</h5>
                                <span class="text-muted">@team.ShortName</span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="text-muted small">City</div>
                            <strong>@team.City</strong>
                        </div>

                        <div class="mb-3">
                            <div class="text-muted small">Stadium</div>
                            <strong>@team.StadiumName</strong>
                        </div>

                        <div class="mb-3">
                            <div class="text-muted small">Manager</div>
                            <strong>@team.ManagerName</strong>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            @if (team.IsActive)
                            {
                                <span class="badge bg-success badge-status">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary badge-status">Passive</span>
                            }

                            <div>
                                <a href="/Admin/AdminTeam/EditTeam/@team.TeamId" class="btn btn-sm btn-outline-primary rounded-pill">
                                    Edit
                                </a>

                                <form asp-area="Admin"
                                      asp-controller="AdminTeam"
                                      asp-action="DeleteTeam"
                                      asp-route-id="@team.TeamId"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('Are you sure you want to delete this team?');">

                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}