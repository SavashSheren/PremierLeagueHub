@model List<PremierLeagueHub.DtoLayer.TeamDtos.ResultTeamDto>

@{
    ViewData["Title"] = "Teams";
    Layout = null;

}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success rounded-4">
        @TempData["SuccessMessage"]
    </div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success rounded-4">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger rounded-4">
        @TempData["ErrorMessage"]
    </div>
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>PremierLeagueHub - Admin Teams</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style> n
        body {
            background: #f4f7fb;
            font-family: Arial, sans-serif;
        }

        .sidebar {
            width: 260px;
            min-height: 100vh;
            background: #101827;
            color: #fff;
            position: fixed;
            left: 0;
            top: 0;
            padding: 24px;
        }

        .sidebar h3 {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 32px;
        }

        .sidebar a {
            display: block;
            color: #cbd5e1;
            text-decoration: none;
            padding: 12px 14px;
            border-radius: 12px;
            margin-bottom: 8px;
        }

        .sidebar a.active,
        .sidebar a:hover {
            background: #1d4ed8;
            color: #fff;
        }

        .main-content {
            margin-left: 260px;
            padding: 32px;
        }

        .page-header {
            background: linear-gradient(135deg, #111827, #1d4ed8);
            color: white;
            border-radius: 24px;
            padding: 32px;
            margin-bottom: 28px;
        }

        .team-card {
            border: 0;
            border-radius: 22px;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
            overflow: hidden;
            transition: 0.25s ease;
        }

        .team-card:hover {
            transform: translateY(-4px);
        }

        .club-strip {
            height: 8px;
        }

        .team-logo {
            width: 74px;
            height: 74px;
            object-fit: contain;
            background: #fff;
            border-radius: 18px;
            padding: 10px;
            border: 1px solid #e5e7eb;
        }

        .badge-status {
            border-radius: 999px;
            padding: 6px 12px;
            font-size: 13px;
        }
    </style>
</head>
<body>

    <aside class="sidebar">
        <h3>PremierLeagueHub</h3>
        <a href="/Admin/AdminTeam/Index" class="active">Teams</a>
        <a href="#">Players</a>
        <a href="#">Fixtures</a>
        <a href="#">Matches</a>
        <a href="#">Standings</a>
    </aside>

    <main class="main-content">
        <section class="page-header">
            <h1 class="mb-2">Team Management</h1>
            <p class="mb-0">Manage Premier League clubs, stadiums, colors and team details.</p>
        </section>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="mb-1">Teams</h4>
                <span class="text-muted">@Model.Count team(s) found</span>
            </div>

            <a href="/Admin/AdminTeam/CreateTeam" class="btn btn-primary rounded-pill px-4">
                Add New Team
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-warning">
                No teams found. Please add teams from the API first.
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var team in Model)
                {
                    <div class="col-xl-4 col-lg-6">
                        <div class="card team-card">
                            <div class="club-strip" style="background:@team.PrimaryColor"></div>

                            <div class="card-body p-4">
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    <img src="@team.LogoUrl" class="team-logo" alt="@team.TeamName logo" />

                                    <div>
                                        <h5 class="mb-1">@team.TeamName</h5>
                                        <span class="text-muted">@team.ShortName</span>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="text-muted small">City</div>
                                    <strong>@team.City</strong>
                                </div>

                                <div class="mb-3">
                                    <div class="text-muted small">Stadium</div>
                                    <strong>@team.StadiumName</strong>
                                </div>

                                <div class="mb-3">
                                    <div class="text-muted small">Manager</div>
                                    <strong>@team.ManagerName</strong>
                                </div>

                                <div class="d-flex justify-content-between align-items-center">
                                    @if (team.IsActive)
                                    {
                                        <span class="badge bg-success badge-status">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary badge-status">Passive</span>
                                    }

                                    <div>
                                        <a href="/Admin/AdminTeam/EditTeam/@team.TeamId" class="btn btn-sm btn-outline-primary rounded-pill">Edit</a>
                                        <form asp-area="Admin"
                                              asp-controller="AdminTeam"
                                              asp-action="DeleteTeam"
                                              asp-route-id="@team.TeamId"
                                              method="post"
                                              class="d-inline"
                                              onsubmit="return confirm('Are you sure you want to delete this team?');">

                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </main>

</body>
</html>