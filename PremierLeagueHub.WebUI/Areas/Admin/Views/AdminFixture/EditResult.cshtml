@model AdminFixtureResultViewModel

@{
    ViewData["Title"] = "Update Match Result";
    ViewData["Description"] = "Set final score and match status for the selected fixture.";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row g-4">
    <div class="col-xl-7">
        <div class="content-card">
            <div class="admin-result-preview mb-4">
                <div class="admin-result-team">
                    <img src="@Model.HomeTeamLogoUrl" alt="@Model.HomeTeamName logo" />
                    <h4>@Model.HomeTeamName</h4>
                </div>

                <div class="admin-result-vs">
                    VS
                </div>

                <div class="admin-result-team">
                    <img src="@Model.AwayTeamLogoUrl" alt="@Model.AwayTeamName logo" />
                    <h4>@Model.AwayTeamName</h4>
                </div>
            </div>

            <div class="row g-3 text-center">
                <div class="col-md-6">
                    <div class="admin-info-box">
                        <span>Match Date</span>
                        <strong>@Model.MatchDate.ToString("dd MMM yyyy HH:mm")</strong>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="admin-info-box">
                        <span>Stadium</span>
                        <strong>@Model.StadiumName</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-5">
        <div class="form-card">
            <form asp-area="Admin" asp-controller="AdminFixture" asp-action="EditResult" method="post">

                <input type="hidden" asp-for="FixtureId" />
                <input type="hidden" asp-for="HomeTeamName" />
                <input type="hidden" asp-for="HomeTeamLogoUrl" />
                <input type="hidden" asp-for="AwayTeamName" />
                <input type="hidden" asp-for="AwayTeamLogoUrl" />
                <input type="hidden" asp-for="MatchDate" />
                <input type="hidden" asp-for="StadiumName" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4"></div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label asp-for="HomeScore" class="form-label">Home Score</label>
                        <input asp-for="HomeScore" type="number" min="0" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="AwayScore" class="form-label">Away Score</label>
                        <input asp-for="AwayScore" type="number" min="0" class="form-control" />
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Status" class="form-label">Match Status</label>
                        <select asp-for="Status" class="form-select">
                            <option value="Scheduled">Scheduled</option>
                            <option value="Live">Live</option>
                            <option value="Finished">Finished</option>
                        </select>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-5">
                    <a href="/Admin/AdminFixture/Index" class="btn btn-light rounded-pill px-4">
                        Back to Fixtures
                    </a>

                    <button type="submit" class="btn btn-primary rounded-pill px-5">
                        Save Result
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>