@model List<ResultFixtureDto>

@{
    ViewData["Title"] = "Fixture Management";
    ViewData["Description"] = "Manage Premier League fixtures, match status and final scores.";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1">Fixtures</h4>
            <p class="text-muted mb-0">@Model.Count fixture(s) found</p>
        </div>

        <a href="/Fixtures/Index" target="_blank" class="btn btn-outline-primary rounded-pill px-4">
            View Public Fixtures
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning rounded-4 mb-0">
            No fixtures found. Run the fixture seed endpoint first.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle admin-table mb-0">
                <thead>
                    <tr>
                        <th>Match</th>
                        <th>Date</th>
                        <th>Stadium</th>
                        <th>Status</th>
                        <th>Score</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var fixture in Model)
                    {
                        <tr>
                            <td>
                                <div class="admin-fixture-match">
                                    <div class="admin-fixture-team">
                                        <img src="@fixture.HomeTeamLogoUrl" alt="@fixture.HomeTeamName logo" />
                                        <span>@fixture.HomeTeamName</span>
                                    </div>

                                    <strong>VS</strong>

                                    <div class="admin-fixture-team">
                                        <img src="@fixture.AwayTeamLogoUrl" alt="@fixture.AwayTeamName logo" />
                                        <span>@fixture.AwayTeamName</span>
                                    </div>
                                </div>
                            </td>

                            <td>
                                <strong>@fixture.MatchDate.ToString("dd MMM yyyy")</strong>
                                <div class="text-muted small">@fixture.MatchDate.ToString("HH:mm")</div>
                            </td>

                            <td>@fixture.StadiumName</td>

                            <td>
                                @if (fixture.Status == "Finished")
                                {
                                    <span class="badge bg-success badge-status">Finished</span>
                                }
                                else if (fixture.Status == "Live")
                                {
                                    <span class="badge bg-danger badge-status">Live</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary badge-status">@fixture.Status</span>
                                }
                            </td>

                            <td>
                                @if (fixture.HasResult)
                                {
                                    <strong>@fixture.HomeScore - @fixture.AwayScore</strong>
                                }
                                else
                                {
                                    <span class="text-muted">Not played</span>
                                }
                            </td>

                            <td class="text-end">
                                <a href="/Admin/AdminFixture/EditResult/@fixture.FixtureId"
                                   class="btn btn-sm btn-primary rounded-pill px-3">
                                    Update Result
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>