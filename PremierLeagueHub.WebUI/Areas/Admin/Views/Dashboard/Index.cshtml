@model AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
    ViewData["Description"] = "Track Premier League teams, activity status and management overview.";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="dashboard-stat-card">
            <div>
                <span>Total Teams</span>
                <h2>@Model.TotalTeams</h2>
            </div>
            <div class="stat-icon bg-primary-subtle text-primary">T</div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="dashboard-stat-card">
            <div>
                <span>Active Teams</span>
                <h2>@Model.ActiveTeams</h2>
            </div>
            <div class="stat-icon bg-success-subtle text-success">A</div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="dashboard-stat-card">
            <div>
                <span>Passive Teams</span>
                <h2>@Model.PassiveTeams</h2>
            </div>
            <div class="stat-icon bg-warning-subtle text-warning">P</div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="dashboard-stat-card">
            <div>
                <span>Cities</span>
                <h2>@Model.TotalCities</h2>
            </div>
            <div class="stat-icon bg-info-subtle text-info">C</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-8">
        <div class="content-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h4 class="mb-1">Latest Teams</h4>
                    <p class="text-muted mb-0">Recently added Premier League clubs.</p>
                </div>

                <a href="/Admin/AdminTeam/Index" class="btn btn-outline-primary rounded-pill px-4">
                    View All
                </a>
            </div>

            @if (!Model.LatestTeams.Any())
            {
                <div class="alert alert-warning rounded-4 mb-0">
                    No teams found yet.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle admin-table mb-0">
                        <thead>
                            <tr>
                                <th>Club</th>
                                <th>City</th>
                                <th>Stadium</th>
                                <th>Manager</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var team in Model.LatestTeams)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <img src="@team.LogoUrl" class="table-team-logo" alt="@team.TeamName logo" />
                                            <div>
                                                <strong>@team.TeamName</strong>
                                                <div class="text-muted small">@team.ShortName</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>@team.City</td>
                                    <td>@team.StadiumName</td>
                                    <td>@team.ManagerName</td>
                                    <td>
                                        @if (team.IsActive)
                                        {
                                            <span class="badge bg-success badge-status">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary badge-status">Passive</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="col-xl-4">
        <div class="content-card">
            <h4 class="mb-1">Quick Actions</h4>
            <p class="text-muted mb-4">Fast management shortcuts.</p>

            <div class="d-grid gap-3">
                <a href="/Admin/AdminTeam/CreateTeam" class="btn btn-primary rounded-pill py-3">
                    Add New Team
                </a>

                <a href="/Admin/AdminTeam/Index" class="btn btn-light rounded-pill py-3">
                    Manage Teams
                </a>
            </div>
        </div>
    </div>
</div>